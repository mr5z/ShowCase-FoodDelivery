<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:behaviors="clr-namespace:Nkraft.MvvmEssentials.Behaviors;assembly=Nkraft.MvvmEssentials"
            xmlns:vm="clr-namespace:FoodDelivery.ViewModels"
            xmlns:pages="clr-namespace:FoodDelivery.Pages"
            x:DataType="vm:MainHostViewModel"
            x:Class="FoodDelivery.Pages.MainHostPage"
            Title="Food Delivery">
    
    <FlyoutPage.Behaviors>
        <behaviors:FlyoutPresentingBehavior />
        
        <behaviors:FlyoutDetailLifecycleBehavior />
    </FlyoutPage.Behaviors>

    <FlyoutPage.Flyout>
        <pages:MenuPage BindingContext="{Binding MenuViewModel}" Title="Menu" />
    </FlyoutPage.Flyout>
    
    <FlyoutPage.Detail>
        <pages:MainTabbedPage BindingContext="{Binding DetailViewModel}" />
    </FlyoutPage.Detail>

</FlyoutPage>