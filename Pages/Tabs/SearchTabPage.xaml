<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodDelivery.ViewModels.Tabs"
             x:Class="FoodDelivery.Pages.Tabs.SearchTabPage"
             x:DataType="vm:SearchTabViewModel"
             Title="{Binding TabTitle}"
             IconImageSource="🔍">
    
    <Grid RowDefinitions="Auto,*">
        
        <!-- Search Bar -->
        <Frame Grid.Row="0" 
               Padding="15"
               Margin="15,15,15,10"
               CornerRadius="25"
               HasShadow="False"
               BackgroundColor="#F8F9FA">
            <Grid ColumnDefinitions="*,Auto">
                <Entry Grid.Column="0"
                       Placeholder="Search for food..."
                       Text="{Binding SearchText}"
                       ReturnCommand="{Binding PerformSearchCommand}"
                       BackgroundColor="Transparent" />
                <Button Grid.Column="1"
                        Text="🔍"
                        FontSize="20"
                        Command="{Binding PerformSearchCommand}"
                        BackgroundColor="Transparent"
                        Padding="10,0" />
            </Grid>
        </Frame>

        <!-- Search Results -->
        <CollectionView Grid.Row="1" 
                       ItemsSource="{Binding SearchResults}"
                       Margin="10,0,10,10">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" 
                                    HorizontalOptions="Center"
                                    Padding="40">
                    <Label Text="🔍" 
                           FontSize="64"
                           HorizontalOptions="Center" />
                    <Label Text="Search for your favorite dishes" 
                           FontSize="16"
                           TextColor="#6C757D"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="15" 
                           Margin="5,5"
                           CornerRadius="12"
                           HasShadow="True"
                           BackgroundColor="White">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectItemCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        
                        <Grid ColumnDefinitions="60,*,Auto" RowDefinitions="Auto,Auto,Auto">
                            
                            <!-- Item Icon -->
                            <Label Grid.Column="0" Grid.RowSpan="3"
                                   Text="{Binding ImageEmoji}"
                                   FontSize="48"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center" />
                            
                            <!-- Item Name -->
                            <Label Grid.Column="1" Grid.Row="0"
                                   Text="{Binding Name}"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            
                            <!-- Description -->
                            <Label Grid.Column="1" Grid.Row="1"
                                   Text="{Binding Description}"
                                   FontSize="13"
                                   TextColor="#6C757D"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />
                            
                            <!-- Category -->
                            <Label Grid.Column="1" Grid.Row="2"
                                   Text="{Binding Category}"
                                   FontSize="12"
                                   TextColor="#FF6B6B"
                                   FontAttributes="Bold"
                                   Margin="0,4,0,0" />
                            
                            <!-- Price -->
                            <Label Grid.Column="2" Grid.RowSpan="3"
                                   Text="{Binding Price, StringFormat='${0:F2}'}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#28A745"
                                   VerticalOptions="Center" />
                            
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
    
</ContentPage>
