<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodDelivery.ViewModels.Tabs"
             xmlns:models="clr-namespace:FoodDelivery.Models"
             x:Class="FoodDelivery.Pages.Tabs.RestaurantsTabPage"
             x:DataType="vm:RestaurantsTabViewModel"
             Title="{Binding TabTitle}"
             IconImageSource="🏪">
    
    <Grid RowDefinitions="Auto,*">
        
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" 
                            Padding="20,15"
                            BackgroundColor="#FF6B6B">
            <Label Text="🍔 Find Your Favorite Food" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   TextColor="White" />
            <Label Text="Choose from our wide selection of restaurants" 
                   FontSize="14" 
                   TextColor="White"
                   Opacity="0.9" />
        </VerticalStackLayout>

        <!-- Restaurant List -->
        <CollectionView Grid.Row="1" 
                       ItemsSource="{Binding Restaurants}"
                       Margin="10,10,10,10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Restaurant">
                    <Border Padding="15" 
                           Margin="5,5"
                           StrokeThickness="0"
                           BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black"
                                   Offset="0,2"
                                   Radius="8"
                                   Opacity="0.1" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RestaurantsTabViewModel}}, Path=SelectRestaurantCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        
                        <Grid ColumnDefinitions="60,*,Auto" RowDefinitions="Auto,Auto,Auto">
                            
                            <!-- Restaurant Icon -->
                            <Label Grid.Column="0" Grid.RowSpan="3"
                                   Text="{Binding ImageEmoji}"
                                   FontSize="48"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center" />
                            
                            <!-- Restaurant Name -->
                            <Label Grid.Column="1" Grid.Row="0"
                                   Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            
                            <!-- Cuisine Type -->
                            <Label Grid.Column="1" Grid.Row="1"
                                   Text="{Binding Cuisine}"
                                   FontSize="14"
                                   TextColor="#6C757D" />
                            
                            <!-- Rating & Delivery Time -->
                            <HorizontalStackLayout Grid.Column="1" Grid.Row="2" Spacing="15">
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="⭐" FontSize="14" />
                                    <Label Text="{Binding Rating}" 
                                           FontSize="14"
                                           FontAttributes="Bold" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="🕐" FontSize="14" />
                                    <Label Text="{Binding DeliveryTime}" 
                                           FontSize="14"
                                           TextColor="#6C757D" />
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>
                            
                            <!-- Arrow -->
                            <Label Grid.Column="2" Grid.RowSpan="3"
                                   Text="›"
                                   FontSize="32"
                                   TextColor="#CED4DA"
                                   VerticalOptions="Center" />
                            
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
    
</ContentPage>