<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:FoodDelivery.ViewModels"
    xmlns:models="clr-namespace:FoodDelivery.Models"
    x:Class="FoodDelivery.Pages.RestaurantDetailPage"
    x:DataType="vm:RestaurantDetailViewModel"
    x:Name="Page"
    Title="{Binding Restaurant.Name}">
    
    <Grid RowDefinitions="Auto,*">
        
        <!-- Restaurant Header -->
        <VerticalStackLayout Grid.Row="0" 
                            Padding="20,15"
                            BackgroundColor="#FF6B6B">
            <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto">
                
                <!-- Restaurant Icon -->
                <Label Grid.Column="0" Grid.RowSpan="3"
                       Text="{Binding Restaurant.ImageEmoji}"
                       FontSize="64"
                       VerticalOptions="Center"
                       HorizontalOptions="Center" />
                
                <!-- Restaurant Name -->
                <Label Grid.Column="1" Grid.Row="0"
                       Text="{Binding Restaurant.Name}"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White" />
                
                <!-- Cuisine -->
                <Label Grid.Column="1" Grid.Row="1"
                       Text="{Binding Restaurant.Cuisine}"
                       FontSize="16"
                       TextColor="White"
                       Opacity="0.9" />
                
                <!-- Info Row -->
                <HorizontalStackLayout Grid.Column="1" Grid.Row="2" 
                                      Spacing="20"
                                      Margin="0,8,0,0">
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="⭐" FontSize="14" />
                        <Label Text="{Binding Restaurant.Rating}" 
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="🕐" FontSize="14" />
                        <Label Text="{Binding Restaurant.DeliveryTime}" 
                               FontSize="14"
                               TextColor="White" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="💵" FontSize="14" />
                        <Label Text="{Binding Restaurant.DeliveryFee, StringFormat='${0:F2}'}" 
                               FontSize="14"
                               TextColor="White" />
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
                
            </Grid>
        </VerticalStackLayout>

        <!-- Menu Items -->
        <CollectionView Grid.Row="1" 
                       ItemsSource="{Binding MenuItems}"
                       Margin="10,10,10,10">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:MenuItem">
                    <VerticalStackLayout>
                        <Border Padding="15" 
                               Margin="5,5"
                               StrokeThickness="0"
                               BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black"
                                       Offset="0,2"
                                       Radius="8"
                                       Opacity="0.1" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:RestaurantDetailViewModel}}, Path=SelectMenuItemCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            
                            <Grid ColumnDefinitions="70,*,Auto" RowDefinitions="Auto,Auto,Auto">
                                
                                <!-- Item Icon -->
                                <Label Grid.Column="0" Grid.RowSpan="3"
                                       Text="{Binding ImageEmoji}"
                                       FontSize="52"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center" />
                                
                                <!-- Popular Badge -->
                                <Border Grid.Column="0"
                                       Padding="6,3"
                                       StrokeThickness="0"
                                       BackgroundColor="#FFD700"
                                       VerticalOptions="Start"
                                       HorizontalOptions="End"
                                       Margin="0,-5,-5,0"
                                       IsVisible="{Binding IsPopular}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Label Text="⭐" FontSize="10" />
                                </Border>
                                
                                <!-- Item Name -->
                                <Label Grid.Column="1" Grid.Row="0"
                                       Text="{Binding Name}"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       Margin="0,0,0,4" />
                                
                                <!-- Description -->
                                <Label Grid.Column="1" Grid.Row="1"
                                       Text="{Binding Description}"
                                       FontSize="13"
                                       TextColor="#6C757D"
                                       LineBreakMode="WordWrap"
                                       MaxLines="2" />
                                
                                <!-- Category -->
                                <Label Grid.Column="1" Grid.Row="2"
                                       Text="{Binding Category}"
                                       FontSize="12"
                                       TextColor="#FF6B6B"
                                       FontAttributes="Bold"
                                       Margin="0,4,0,0" />
                                
                                <!-- Price & Add Button -->
                                <VerticalStackLayout Grid.Column="2" Grid.RowSpan="3"
                                                    VerticalOptions="Center"
                                                    Spacing="8">
                                    <Label Text="{Binding Price, StringFormat='${0:F2}'}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="#28A745"
                                           HorizontalTextAlignment="End" />
                                    <Button Text="+"
                                            FontSize="20"
                                            BackgroundColor="#28A745"
                                            TextColor="White"
                                            WidthRequest="40"
                                            HeightRequest="40"
                                            CornerRadius="20"
                                            Padding="0" />
                                </VerticalStackLayout>
                                
                            </Grid>
                        </Border>
                        
                        <!-- Separator Line -->
                        <BoxView HeightRequest="1" 
                                Color="#F0F0F0" 
                                Margin="15,0,15,0" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
    
</ContentPage>