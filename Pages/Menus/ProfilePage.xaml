<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodDelivery.ViewModels.Menus"
             x:Class="FoodDelivery.Pages.Menus.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="Profile">
    
    <Grid RowDefinitions="Auto,*">
        
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" 
                             Spacing="10"
                             Padding="20" 
                             BackgroundColor="#6F42C1">
            <Label Text="👤" 
                   FontSize="60"
                   HorizontalOptions="Center" />
            <Label Text="John Doe" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />
            <Label Text="john.doe@example.com" 
                   FontSize="14" 
                   TextColor="White"
                   Opacity="0.9"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Profile Info -->
        <ScrollView Grid.Row="1" Padding="20">
            <VerticalStackLayout Spacing="15">
                
                <Border Padding="15" 
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Shadow="{Shadow Brush=Black, Opacity=0.1, Radius=8, Offset='0,2'}">
                    <Grid ColumnDefinitions="Auto,*" 
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="5">
                        <Label Grid.Row="0" Grid.Column="0" 
                               Grid.RowSpan="2"
                               Text="📧" 
                               FontSize="24"
                               VerticalOptions="Center" />
                        <Label Grid.Row="0" Grid.Column="1" 
                               Text="Email" 
                               FontSize="14" 
                               TextColor="#6C757D" />
                        <Label Grid.Row="1" Grid.Column="1" 
                               Text="john.doe@example.com" 
                               FontSize="16" 
                               FontAttributes="Bold" />
                    </Grid>
                </Border>

                <Border Padding="15" 
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Shadow="{Shadow Brush=Black, Opacity=0.1, Radius=8, Offset='0,2'}">
                    <Grid ColumnDefinitions="Auto,*" 
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="5">
                        <Label Grid.Row="0" Grid.Column="0" 
                               Grid.RowSpan="2"
                               Text="📱" 
                               FontSize="24"
                               VerticalOptions="Center" />
                        <Label Grid.Row="0" Grid.Column="1" 
                               Text="Phone" 
                               FontSize="14" 
                               TextColor="#6C757D" />
                        <Label Grid.Row="1" Grid.Column="1" 
                               Text="+1 (555) 123-4567" 
                               FontSize="16" 
                               FontAttributes="Bold" />
                    </Grid>
                </Border>

                <Border Padding="15" 
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Shadow="{Shadow Brush=Black, Opacity=0.1, Radius=8, Offset='0,2'}">
                    <Grid ColumnDefinitions="Auto,*" 
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="5">
                        <Label Grid.Row="0" Grid.Column="0" 
                               Grid.RowSpan="2"
                               Text="📍" 
                               FontSize="24"
                               VerticalOptions="Center" />
                        <Label Grid.Row="0" Grid.Column="1" 
                               Text="Delivery Address" 
                               FontSize="14" 
                               TextColor="#6C757D" />
                        <Label Grid.Row="1" Grid.Column="1" 
                               Text="123 Main St, Apt 4B" 
                               FontSize="16" 
                               FontAttributes="Bold" 
                               LineBreakMode="WordWrap" />
                    </Grid>
                </Border>
                
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
    
</ContentPage>