<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodDelivery.ViewModels"
             x:Class="FoodDelivery.Pages.OrdersPage"
             x:DataType="vm:OrdersViewModel"
             Title="My Orders">
    
    <Grid RowDefinitions="Auto,*">
        
        <!-- Header -->
        <Border Grid.Row="0"
                Padding="20"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,20,20"
                BackgroundColor="#007BFF"
                Margin="0,0,0,10"
                Shadow="{Shadow Brush=Black, Opacity=0.15, Radius=10, Offset='0,2'}">
            <VerticalStackLayout Spacing="5">
                <Label Text="📋 My Orders" 
                       FontSize="28" 
                       FontAttributes="Bold"
                       TextColor="White" />
                <Label Text="View your order history" 
                       FontSize="14" 
                       TextColor="White"
                       Opacity="0.9" />
            </VerticalStackLayout>
        </Border>

        <!-- Orders List -->
        <CollectionView Grid.Row="1"
                       ItemsSource="{Binding Orders}"
                       Margin="10,10,10,10">
            
            <!-- Empty State -->
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    Padding="40"
                                    Spacing="15">
                    <Label Text="📋" 
                           FontSize="80"
                           HorizontalOptions="Center" />
                    <Label Text="No Orders Yet" 
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalOptions="Center" />
                    <Label Text="Start ordering delicious food!" 
                           FontSize="16"
                           TextColor="#6C757D"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            
            <!-- Order Items -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="15"
                            Margin="5,5"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="White"
                            Shadow="{Shadow Brush=Black, Opacity=0.1, Radius=8, Offset='0,2'}">
                        
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                            
                            <!-- Order Header -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding OrderNumber, StringFormat='Order #{0}'}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Grid.Column="1"
                                       Text="{Binding Status}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#28A745"
                                       BackgroundColor="#E8F5E9"
                                       Padding="8,4"
                                       HorizontalOptions="End" />
                            </Grid>
                            
                            <!-- Order Date -->
                            <Label Grid.Row="1"
                                   Text="{Binding OrderDate, StringFormat='{0:MMM dd, yyyy h:mm tt}'}"
                                   FontSize="13"
                                   TextColor="#6C757D" />
                            
                            <!-- Items Count -->
                            <Label Grid.Row="2"
                                   Text="{Binding ItemsCount, StringFormat='{0} items'}"
                                   FontSize="14"
                                   TextColor="#6C757D" />
                            
                            <!-- Total -->
                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="Total"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                                <Label Grid.Column="1"
                                       Text="{Binding Total, StringFormat='${0:F2}'}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#007BFF" />
                            </Grid>
                            
                        </Grid>
                        
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            
        </CollectionView>

    </Grid>
    
</ContentPage>