<?xml version="1.0" encoding="utf-8" ?>
<nkraft:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:nkraft="clr-namespace:Nkraft.MvvmEssentials.Pages;assembly=Nkraft.MvvmEssentials"
                  xmlns:vm="clr-namespace:FoodDelivery.ViewModels"
                  x:Class="FoodDelivery.Pages.ConfirmRemoveItemPopup"
                  x:DataType="vm:ConfirmRemoveItemViewModel"
                  BackgroundColor="#80000000">
    
    <Border WidthRequest="320"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 20"
            BackgroundColor="White"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Shadow="{Shadow Brush=Black, Opacity=0.2, Radius=15, Offset='0,4'}">
        
        <Grid RowDefinitions="Auto,Auto,Auto">
            
            <!-- Header -->
            <Border Grid.Row="0"
                    Padding="20,15"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20,20,0,0"
                    BackgroundColor="#FF6B6B">
                <VerticalStackLayout Spacing="5">
                    <Label Text="⚠️ Remove Item" 
                           FontSize="20" 
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Are you sure?" 
                           FontSize="13" 
                           TextColor="White"
                           Opacity="0.9"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Content -->
            <VerticalStackLayout Grid.Row="1" 
                                Padding="20"
                                Spacing="15">
                
                <!-- Item Icon -->
                <Label Text="{Binding Item.ImageEmoji}"
                       FontSize="48"
                       HorizontalOptions="Center" />
                
                <!-- Item Name -->
                <Label Text="{Binding Item.Name}"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center" />
                
                <!-- Confirmation Message -->
                <Label Text="This item will be removed from your cart."
                       FontSize="14"
                       TextColor="#6C757D"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />
                
            </VerticalStackLayout>

            <!-- Buttons -->
            <Grid Grid.Row="2" 
                  ColumnDefinitions="*,*"
                  Padding="15"
                  ColumnSpacing="10">
                
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="#6C757D"
                        TextColor="White"
                        FontSize="15"
                        HeightRequest="48"
                        CornerRadius="12" />
                
                <Button Grid.Column="1"
                        Text="Remove"
                        Command="{Binding ConfirmCommand}"
                        BackgroundColor="#FF6B6B"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        CornerRadius="12" />
                
            </Grid>

        </Grid>
        
    </Border>
    
</nkraft:PopupPage>