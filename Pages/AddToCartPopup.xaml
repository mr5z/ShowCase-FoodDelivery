<?xml version="1.0" encoding="utf-8" ?>
<nkraft:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:nkraft="clr-namespace:Nkraft.MvvmEssentials.Pages;assembly=Nkraft.MvvmEssentials"
                  xmlns:vm="clr-namespace:FoodDelivery.ViewModels"
                  x:Class="FoodDelivery.Pages.AddToCartPopup"
                  x:DataType="vm:AddToCartViewModel"
                  BackgroundColor="#80000000">
    
    <Border Margin="20"
            StrokeThickness="0"
            BackgroundColor="White"
            VerticalOptions="Center"
            HorizontalOptions="Fill">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20" />
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow Brush="Black"
                   Opacity="0.2"
                   Radius="15"
                   Offset="0,4" />
        </Border.Shadow>
        
        <Grid RowDefinitions="Auto,Auto,Auto">
            
            <!-- Header -->
            <Border Grid.Row="0"
                    Padding="20,20"
                    StrokeThickness="0"
                    BackgroundColor="#28A745">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20,20,0,0" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="5">
                    <Label Text="Add to Cart" 
                           FontSize="22" 
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Customize your order" 
                           FontSize="14" 
                           TextColor="White"
                           Opacity="0.9"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Content -->
            <VerticalStackLayout Grid.Row="1" 
                                Padding="25,20"
                                Spacing="15">
                
                <!-- Item Icon -->
                <Label Text="{Binding Item.ImageEmoji}"
                       FontSize="80"
                       HorizontalOptions="Center" />
                
                <!-- Item Name -->
                <Label Text="{Binding Item.Name}"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="Black"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />
                
                <!-- Item Description -->
                <Label Text="{Binding Item.Description}"
                       FontSize="14"
                       TextColor="#999999"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />
                
                <BoxView HeightRequest="1" 
                        Color="#E0E0E0" 
                        Margin="0,10,0,10" />
                
                <!-- Quantity Selector -->
                <VerticalStackLayout Spacing="15">
                    <Label Text="Quantity" 
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="Black"
                           HorizontalOptions="Center" />
                    
                    <HorizontalStackLayout Spacing="20" 
                                          HorizontalOptions="Center"
                                          VerticalOptions="Center">
                        <Button Text="−"
                                Command="{Binding DecreaseQuantityCommand}"
                                WidthRequest="50"
                                HeightRequest="50"
                                CornerRadius="25"
                                BackgroundColor="#FF6B6B"
                                TextColor="White"
                                FontSize="28"
                                FontAttributes="Bold"
                                Padding="0"
                                VerticalOptions="Center" />
                        
                        <Border WidthRequest="60"
                               HeightRequest="60"
                               StrokeThickness="2"
                               Stroke="#E0E0E0"
                               BackgroundColor="White"
                               VerticalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="{Binding Quantity}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="Black"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center" />
                        </Border>
                        
                        <Button Text="+"
                                Command="{Binding IncreaseQuantityCommand}"
                                WidthRequest="50"
                                HeightRequest="50"
                                CornerRadius="25"
                                BackgroundColor="#28A745"
                                TextColor="White"
                                FontSize="28"
                                FontAttributes="Bold"
                                Padding="0"
                                VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
                
                <!-- Total Price -->
                <Label Text="{Binding TotalPrice, StringFormat='${0:F2}', FallbackValue='$0.00'}"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#28A745"
                       HorizontalOptions="Center"
                       Margin="0,10,0,0" />
                
            </VerticalStackLayout>

            <!-- Buttons -->
            <Grid Grid.Row="2" 
                  ColumnDefinitions="*,*"
                  Padding="20,0,20,20"
                  ColumnSpacing="12">
                
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="#6C757D"
                        TextColor="White"
                        FontSize="16"
                        HeightRequest="50"
                        CornerRadius="12" />
                
                <Button Grid.Column="1"
                        Text="Add to Cart"
                        Command="{Binding AddToCartCommand}"
                        BackgroundColor="#28A745"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="12" />
                
            </Grid>

        </Grid>
        
    </Border>
    
</nkraft:PopupPage>