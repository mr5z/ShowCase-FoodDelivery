<?xml version="1.0" encoding="utf-8" ?>
<nkraft:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                  xmlns:nkraft="clr-namespace:Nkraft.MvvmEssentials.Pages;assembly=Nkraft.MvvmEssentials"
                  xmlns:vm="clr-namespace:FoodDelivery.ViewModels"
                  x:Class="FoodDelivery.Pages.AddToCartPopup"
                  x:DataType="vm:AddToCartViewModel"
                  BackgroundColor="#80000000">
    
    <Border WidthRequest="350"
            MaximumHeightRequest="600"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 20"
            BackgroundColor="White"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Shadow="{Shadow Brush=Black, Opacity=0.2, Radius=15, Offset='0,4'}">
        
        <Grid RowDefinitions="Auto,*,Auto">
            
            <!-- Header -->
            <Border Grid.Row="0"
                    Padding="20,15"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20,20,0,0"
                    BackgroundColor="#28A745">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Add to Cart" 
                           FontSize="20" 
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    <Label Text="Customize your order" 
                           FontSize="13" 
                           TextColor="White"
                           Opacity="0.9"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Content -->
            <ScrollView Grid.Row="1" Padding="20,15">
                <VerticalStackLayout Spacing="15">
                    
                    <!-- Item Icon -->
                    <Label Text="{Binding Item.ImageEmoji}"
                           FontSize="64"
                           HorizontalOptions="Center" />
                    
                    <!-- Item Name -->
                    <Label Text="{Binding Item.Name}"
                           FontSize="20"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center" />
                    
                    <!-- Item Description -->
                    <Label Text="{Binding Item.Description}"
                           FontSize="13"
                           TextColor="#6C757D"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"
                           MaxLines="2" />
                    
                    <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,5" />
                    
                    <!-- Quantity Selector -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Quantity" 
                               FontSize="15"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        
                        <HorizontalStackLayout Spacing="15" 
                                              HorizontalOptions="Center">
                            <Button Text="-"
                                    Command="{Binding DecreaseQuantityCommand}"
                                    WidthRequest="45"
                                    HeightRequest="45"
                                    CornerRadius="22"
                                    BackgroundColor="#FF6B6B"
                                    TextColor="White"
                                    FontSize="22"
                                    Padding="0" />
                            
                            <Label Text="{Binding Quantity}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   WidthRequest="45"
                                   HorizontalTextAlignment="Center" />
                            
                            <Button Text="+"
                                    Command="{Binding IncreaseQuantityCommand}"
                                    WidthRequest="45"
                                    HeightRequest="45"
                                    CornerRadius="22"
                                    BackgroundColor="#28A745"
                                    TextColor="White"
                                    FontSize="22"
                                    Padding="0" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    
                    <!-- Total Price -->
                    <Border Padding="12"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="#F8F9FA">
                        <HorizontalStackLayout Spacing="8" 
                                              HorizontalOptions="Center">
                            <Label Text="Total:" 
                                   FontSize="16"
                                   VerticalOptions="Center" />
                            <Label Text="{Binding TotalPrice, StringFormat='${0:F2}'}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="#28A745"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                    
                </VerticalStackLayout>
            </ScrollView>

            <!-- Buttons -->
            <Grid Grid.Row="2" 
                  ColumnDefinitions="*,*"
                  Padding="15"
                  ColumnSpacing="10">
                
                <Button Grid.Column="0"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="#6C757D"
                        TextColor="White"
                        FontSize="15"
                        HeightRequest="48"
                        CornerRadius="12" />
                
                <Button Grid.Column="1"
                        Text="Add to Cart"
                        Command="{Binding AddToCartCommand}"
                        BackgroundColor="#28A745"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        HeightRequest="48"
                        CornerRadius="12" />
                
            </Grid>

        </Grid>
        
    </Border>
    
</nkraft:PopupPage>