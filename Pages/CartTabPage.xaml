<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FoodDelivery.ViewModels"
             x:Class="FoodDelivery.Pages.CartTabPage"
             x:DataType="vm:CartTabViewModel"
             Title="{Binding TabTitle}"
             IconImageSource="🛒">
    
    <Grid RowDefinitions="Auto,*,Auto">
        
        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" 
                            Padding="20,15"
                            BackgroundColor="#28A745">
            <Label Text="🛒 Your Cart" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   TextColor="White" />
            <Label Text="{Binding TotalItems, StringFormat='{0} items'}" 
                   FontSize="14" 
                   TextColor="White"
                   Opacity="0.9" />
        </VerticalStackLayout>

        <!-- Cart Items -->
        <CollectionView Grid.Row="1" 
                       ItemsSource="{Binding CartItems}"
                       Margin="10,10,10,10">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" 
                                    HorizontalOptions="Center"
                                    Padding="40">
                    <Label Text="🛒" 
                           FontSize="64"
                           HorizontalOptions="Center" />
                    <Label Text="Your cart is empty" 
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,10,0,5" />
                    <Label Text="Add items from restaurants to get started!" 
                           FontSize="14"
                           TextColor="#6C757D"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="15" 
                            Margin="5,5"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="White"
                            Shadow="{Shadow Brush=Black, Opacity=0.1, Radius=8, Offset='0,2'}">
                        
                        <Grid ColumnDefinitions="60,*,Auto" RowDefinitions="Auto,Auto,Auto">
                            
                            <!-- Item Icon -->
                            <Label Grid.Column="0" Grid.RowSpan="3"
                                   Text="{Binding Item.ImageEmoji}"
                                   FontSize="48"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center" />
                            
                            <!-- Item Name -->
                            <Label Grid.Column="1" Grid.Row="0"
                                   Text="{Binding Item.Name}"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                            
                            <!-- Price per item -->
                            <Label Grid.Column="1" Grid.Row="1"
                                   Text="{Binding Item.Price, StringFormat='${0:F2} each'}"
                                   FontSize="13"
                                   TextColor="#6C757D" />
                            
                            <!-- Quantity Controls -->
                            <HorizontalStackLayout Grid.Column="1" Grid.Row="2" 
                                                  Spacing="10"
                                                  Margin="0,8,0,0">
                                <Button Text="-"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DecreaseQuantityCommand}"
                                        CommandParameter="{Binding .}"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"
                                        BackgroundColor="#FF6B6B"
                                        TextColor="White"
                                        FontSize="20"
                                        Padding="0" />
                                
                                <Label Text="{Binding Quantity}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       WidthRequest="30"
                                       HorizontalTextAlignment="Center" />
                                
                                <Button Text="+"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IncreaseQuantityCommand}"
                                        CommandParameter="{Binding .}"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        CornerRadius="20"
                                        BackgroundColor="#28A745"
                                        TextColor="White"
                                        FontSize="20"
                                        Padding="0" />
                            </HorizontalStackLayout>
                            
                            <!-- Total Price & Remove -->
                            <VerticalStackLayout Grid.Column="2" Grid.RowSpan="3"
                                                VerticalOptions="Center"
                                                Spacing="10">
                                <Label Text="{Binding Total, StringFormat='${0:F2}'}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#28A745"
                                       HorizontalTextAlignment="End" />
                                <Button Text="🗑️"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveItemCommand}"
                                        CommandParameter="{Binding .}"
                                        FontSize="16"
                                        BackgroundColor="Transparent"
                                        TextColor="#DC3545"
                                        Padding="5" />
                            </VerticalStackLayout>
                            
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Checkout Section -->
        <Border Grid.Row="2"
                Padding="20"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 20,20,0,0"
                BackgroundColor="White"
                Margin="0,-10,0,0"
                Shadow="{Shadow Brush=Black, Opacity=0.15, Radius=10, Offset='0,-2'}">
            <VerticalStackLayout Spacing="15">
                
                <!-- Subtotal -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" 
                           Text="Subtotal" 
                           FontSize="16"
                           TextColor="#6C757D" />
                    <Label Grid.Column="1" 
                           Text="{Binding Subtotal, StringFormat='${0:F2}'}"
                           FontSize="16"
                           FontAttributes="Bold" />
                </Grid>

                <!-- Checkout Button -->
                <Button Text="Proceed to Checkout"
                        Command="{Binding CheckoutCommand}"
                        BackgroundColor="#28A745"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="55"
                        CornerRadius="12"
                        IsEnabled="{Binding CartItems.Count}" />
                
            </VerticalStackLayout>
        </Border>

    </Grid>
    
</ContentPage>